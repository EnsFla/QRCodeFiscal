// prisma/schema.prisma
datasource db {
  provider = "sqlite"
  url      = "file:./dev.sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Reimbursement {
  id          Int      @id @default(autoincrement())
  accessKey   String   @unique 
  totalValue  Float
  date        DateTime @default(now())
  status      String   
  notes       String?
}